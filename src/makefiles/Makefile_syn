# TCL scripts
FORMAT=INT
WIDTH=4

PRJ=../..
TARGET_DIR=$(FORMAT)$(WIDTH)

.PHONY: prep design clean

run:
	$(MAKE) prep
	$(MAKE) design

prep:
	mkdir -p $(TARGET_DIR)
	cd $(TARGET_DIR) && ln -s -f $(PRJ)/src/makefiles/Makefile_syn_sub Makefile

design: 
	$(MAKE) -C $(TARGET_DIR) design WIDTH=$(WIDTH) FORMAT=$(FORMAT)

clean:
	$(MAKE) -C $(TARGET_DIR) clean