# TCL scripts
TOPLEVEL=matrix_mult_wrapper
FORMAT=INT
WIDTH=8
ROW=8
COL=8

PRJ=../..
RTL_DIR=$(PRJ)/src/rtl
SRC_TCL=$(PRJ)/src/syn

TCL_MAIN=synthesis.tcl
TCL_DEFINE=define.tcl
TMP_FOLDER=/tmp/$(USER)/

# Directories
RESULTDIR=./results 
REPORTDIR=./reports

design: 
	-make clean
	-make dc

dc: results/$(TOPLEVEL).syn.v

$(TCL_DEFINE):
	echo "set DEFINE_LIST [list WIDTH=$(WIDTH) $(FORMAT) ROW=$(ROW) COL=$(COL)]" > $(TCL_DEFINE)

$(TCL_MAIN): $(TCL_DEFINE)
	find $(SRC_TCL) -name '*.tcl' -exec ln -s -f {} ';'

results/$(TOPLEVEL).syn.v: $(TCL_MAIN)
	dc_shell -64bit -topo -output_log_file dc.log -f $(TCL_MAIN)

clean:
	-@ rm -rf $(TOPLEVEL)_lib \
			  $(RESULTDIR) \
			  $(REPORTDIR) \
			  alib-52 \
			  *.sv \
			  *.svh \
			  *.tcl \
			  DC_lib\
			  WORK \
			  *.log \
			  rtl \
			  *.svf \
			  moduleparamid
